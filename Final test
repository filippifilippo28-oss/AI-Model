# Decomprimi il file zip scaricato
unzip capstone_project.zip

# Entra nella cartella
cd capstone
# Inizializza il repository Git
git init

# Aggiungi tutti i file
git add .

# Primo commit
git commit -m "Initial commit: GDP forecasting capstone project"

# Collega al repository GitHub (sostituisci con il TUO url)
git remote add origin https://github.com/tuousername/gdp-forecasting-capstone.git

# Carica tutto su GitHub
git branch -M main
git push -u origin main

# Crea il file .gitignore
cat > .gitignore << EOF
__pycache__/
*.pyc
*.pkl
*.egg-info/
.env
logs/*.log
data/gdp_data.csv
.DS_Store
.ipynb_checkpoints/
EOF

git add .gitignore
git commit -m "Add .gitignore"
git push


